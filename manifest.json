{
  "manifest_version": 3,
  "name": "한눈에 이잘키 정오표",
  "short_name": "이잘키 정오표",
  "version": "1.0.3",
  "description": "HoYoLAB 원신, 스타레일, 젠존제 캐릭터 정보를 기준표와 비교해 리포트를 만듭니다.",
  "icons": {
    "16": "src/genshin/assets/icon-16.png",
    "32": "src/genshin/assets/icon-32.png",
    "48": "src/genshin/assets/icon-48.png",
    "128": "src/genshin/assets/icon-128.png"
  },
  "action": {
    "default_title": "이잘키 정오표 HoYoverse",
    "default_icon": {
      "16": "src/genshin/assets/icon-16.png",
      "32": "src/genshin/assets/icon-32.png",
      "48": "src/genshin/assets/icon-48.png",
      "128": "src/genshin/assets/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "host_permissions": [
    "https://docs.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://act.hoyolab.com/app/community-game-records-sea/index.html*"
      ],
      "js": [
        "src/common/content-injector.js",
        "src/genshin/content/inject-hoyolab-response-hook.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://act.hoyolab.com/app/community-game-records-sea/index.html*",
        "https://act.hoyolab.com/app/community-game-records-sea/rpg/index.html*",
        "https://act.hoyolab.com/app/community-game-records-sea/rpg/m.html*"
      ],
      "js": [
        "src/common/content-injector.js",
        "src/hsr/content/inject-hoyolab-response-hook.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://act.hoyolab.com/app/zzz-game-record/index.html*"
      ],
      "js": [
        "src/common/content-injector.js",
        "src/zzz/content/inject-hoyolab-response-hook.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/genshin/injected/*.js",
        "src/genshin/assets/*.png",
        "src/genshin/assets/*.webp",
        "src/genshin/assets/*.svg",
        "src/common/injected/*.js",
        "src/hsr/injected/*.js",
        "src/hsr/assets/*.png",
        "src/hsr/assets/*.webp",
        "src/hsr/assets/*.svg",
        "src/zzz/injected/*.js",
        "src/zzz/assets/*.png",
        "src/zzz/assets/*.webp",
        "src/zzz/assets/*.svg"
      ],
      "matches": [
        "https://act.hoyolab.com/*"
      ]
    }
  ]
}
